{
  "version": 2,
  "rewrites": [
    {
      "source": "/api-docs",
      "destination": "/index.js"
    },
    {
      "source": "/api-docs/(.*)",
      "destination": "/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.js"
    }
  ],
  "functions": {
    "index.js": {
      "includeFiles": "swagger.yaml"
    }
  }
}
